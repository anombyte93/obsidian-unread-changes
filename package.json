{
	"name": "obsidian-unread-changes",
	"version": "0.1.1",
	"description": "Unread-message awareness for human+AI co-edited Obsidian vaults",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "eslint src",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"unread",
		"changelog",
		"attribution"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/diff": "^7.0.2",
		"@types/node": "^22.0.0",
		"builtin-modules": "^4.0.0",
		"esbuild": "^0.25.0",
		"eslint": "^10.6.0",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"obsidian": "^1.13.1",
		"tslib": "^2.8.0",
		"typescript": "^5.9.0",
		"typescript-eslint": "^8.63.0",
		"vitest": "^3.0.0"
	},
	"dependencies": {
		"diff": "^7.0.0"
	}
}
